rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Function to check if user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists;
    }
    
    // Allow all authenticated users to read their own data
    // and create their own user documents
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
    
    // Matches - allow authenticated users to read/write their matches
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    
    // Chats - allow authenticated users to read/write their chats
    // Note: chat membership isn't enforced here; you can tighten later.
    match /chats/{chatId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    
    // Messages subcollection
    match /chats/{chatId}/messages/{messageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Reports - allow authenticated users to create, admins to read/update
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }
    
    // Admins collection
    // - Any authenticated user may read *only their own* admin doc (used by AuthService.isAdmin)
    // - Writes are admin-only (typically via Firebase Console / Admin SDK)
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    // Optional: allow authenticated users to read their own match-related chat messages by checking membership
    // (your app stores chats as /chats/{chatId}, but doesn't model membership in rules yet)

  }
}
